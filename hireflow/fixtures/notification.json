  "email_template": "Application Received",
  "event": "Value Change",
  "document_type": "Job Application",
  "enabled": 1,
  "module": "HireFlow",
  "channel": "Email",
  "value_changed": "status",
  "condition": "doc.status == 'Applied'"
 },
 {
  "doctype": "Notification",
  "name": "Interview Scheduled",
  "subject": "Interview Scheduled for {{ candidate }}",
  "email_template": "Interview Invitation",
  "event": "Value Change",
  "document_type": "Interview Schedule",
  "enabled": 1,
  "module": "HireFlow",
  "channel": "Email",
  "value_changed": "status",
  "condition": "doc.status == 'Scheduled'"
 },
 {
  "doctype": "Notification",
  "name": "Interview Reminder",
  "subject": "Interview Reminder - Tomorrow",
  "email_template": "Interview Reminder",
  "event": "Days Before",
  "document_type": "Interview Schedule",
  "enabled": 1,
  "module": "HireFlow",
  "channel": "Email",
